TC_ENVIRONMENT=local
TC_RELEASE_VERSION=dev
TC_SCHEMA_VERSION_MIN=1.0.0
TC_SCHEMA_VERSION_MAX=1.0.0
TC_GATEWAY_LISTEN_ADDR=:8080
TC_GATEWAY_PUBLIC_BASE_PATH=/api/v1
TC_GATEWAY_REQUEST_TIMEOUT_MS=15000
TC_GATEWAY_SHUTDOWN_TIMEOUT_MS=30000
